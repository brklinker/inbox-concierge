# Copy to .env.local for local dev; set the same vars in Vercel for prod.

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth web client (Google Cloud console → Credentials).
# Authorized redirect URI (local): http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Neon Postgres connection string (pooled). Migrations enable pgvector.
DATABASE_URL=

# One key covers classification (gpt-4o-mini) and embeddings (text-embedding-3-small).
OPENAI_API_KEY=

# Optional: override the classification model.
# OPENAI_CLASSIFY_MODEL=gpt-4o-mini
